{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whisply",
  "version": "0.0.2",
  "identifier": "com.whisply.dev",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "whisply",
        "width": 1400,
        "height": 918,
        "minWidth": 768,
        "minHeight": 500,
        "center": true,
        "maximized": true,
        "decorations": false,
        "visible": false
      },
      {
        "label": "onboarding",
        "title": "Welcome to Whisply",
        "url": "onboarding.html",
        "width": 760,
        "height": 720,
        "minWidth": 620,
        "minHeight": 540,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "librsvg2", "openssl"]
      },
      "appimage": {}
    },
    "resources": [],
    "publisher": null,
    "license": null,
    "homepage": null,
    "category": "Utility"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1MjUwMjc4NUY0RTM2QzEKUldUQk5rNWZlQUlsOVhzTXpUN1hJSlFDcUVlODVVbGRyR09NNnRtYk8vMFZPLzJuVjRMZUpxR1cK",
      "endpoints": [
        "https://github.com/abboskhonov/whisply/releases/latest/download/latest.json"
      ]
    }
  }
}
